{% extends 'base.html.twig' %}

{% block title %}Hello WerbungController!{% endblock %}

{% block body %}
<style>
.werbung-edit{
    height:750px;
}
.werbung-edit h1{
     font-size:100px;
}
.werbung-edit .image-video .image img{
    width:300px;
    height:300px;
}
.werbung-edit input, .werbung-edit label, .werbung-edit textarea{
    font-size:50px;
}
input::placeholder{
    font-size:30px;
}
.werbung-edit .btn-update{
    background-color: #820263;;
    color:white;
     font-size:50px;
}
.werbung-edit .text-danger{
    font-size:30px;
}

</style>

<div class="werbung-edit p-5">
    <h1 class="text-center">Update 'Werbung'</h1>
            <div class="image-video row">
                <div class="col-6 image">
                    {% if werbung.image is not empty %}
                        <div><img src="/file/werbung/{{ werbung.image }}"></div>
                        {% else %}
                        <div><p>NO Image</p></div>
                    {% endif %}
                </div>
                <div class="col-6 video">
                    {% if werbung.video is not empty %}
                        <video controls class="w-100">
                        <source src="/file/werbung/{{ werbung.video }}" type="video/mp4">
                        </video>
                        {% else %}
                        <div><p>NO Video</p></div>
                    {% endif %}
                </div>
            </div>
    <form class="form h-100 p-2" action="{{ path('werbung.update') }}" method="post" enctype="multipart/form-data">
        <div class="mb-3 mt-5 h-25">
            <label for="exampleFormControlInput1" class="form-label">Nr*:</label>
            <input value='{{ werbung.nr }}' type="number" name="nr" class="form-control h-50" id="exampleFormControlInput1" placeholder="Nr..." required>
            {% if data.err.nr is defined and data.err.nr is not empty %}
                <div class="text-danger mb-4"> {{ data.err.nr}}</div>
            {% endif %}
        </div>
        <div class="mb-3 mt-5 h-25">
            <label for="exampleFormControlInput1" class="form-label">Title:</label>
            <input value='{{ werbung.title }}' type="text" name="title" class="form-control h-50" placeholder="Title..">

        </div>
        <div class="mb-3 mt-5 h-25">
            <label for="exampleFormControlInput1" class="form-label">Price:</label>
            <input type="number" step="0.1" name="price" class="form-control h-50" placeholder="Price.." value='{{ werbung.price }}'>
        </div>
        <div class="mb-5 mt-5 h-25">
            <label for="exampleFormControlTextarea1" class="form-label">Description</label>
            <textarea name="description" class="form-control h-100" id="exampleFormControlTextarea1" rows="3">
            {{werbung.description}}
            </textarea>
        </div>
        <div class="mb-5 mt-5 h-25">
            <label for="exampleFormControlTextarea1" class="form-label">Image</label>
             <input type="file"  name="image" class="form-control h-50">
            {% if data.err.image is defined and data.err.image is not empty %}
                <div class="text-danger"> <p>{{ data.err.image}}</p></div>
            {% endif %}
        </div>
        <div class="mb-3 mt-5 h-25">
            <label for="exampleFormControlTextarea1" class="form-label">Video</label>
             <input type="file"  name="video" class="form-control h-50">
            {% if data.err.video is defined and data.err.video is not empty %}
                <div class="text-danger"> {{ data.err.video}}</div>
            {% endif %}
        </div>
        <div class="mb-3 mt-5 h-25">
            <label for="exampleFormControlInput1" class="form-label">Length of Video:</label>
            <input type="number" step="0.01" name="length" class="form-control h-50" placeholder="Length in Sec..." value='{{werbung.length}}'>
        </div>
        <div class="row">
           <h1 class="fw-large">Screens</h1>
        {% for screen in screens %}
            {% set show = false %}
            {% for werbungScreen in werbung.screens %}
                {% if screen.id == werbungScreen.id %}
                    {% set show = true %}
                {% endif %}
            {% endfor %}
            {% if show == true %}
                <div class="form-check col-md-12">
                    <input value="{{ screen.id }}" class="form-check-input" type="checkbox" name="screen{{ screen.id }}"id="flexCheckDefault" checked>
                    <label class="form-check-label" for="flexCheckDefault">
                        {{ screen.title }}
                    </label>
                </div>
                {% else %}
                <div class="form-check col-md-12">
                    <input value="{{ screen.id }}" class="form-check-input" type="checkbox" name="screen{{ screen.id }}" id="flexCheckDefault">
                    <label class="form-check-label" for="flexCheckDefault">
                        {{ screen.title }}
                    </label>
                </div>
            {% endif %}
        {% endfor %}
        {% if data.err.screen is defined and data.err.screen is not empty %}
            <div class="text-danger mb-4"> {{ data.err.screen}}</div>
        {% endif %}
        </div>
        <input type="hidden" value="{{werbung.id}}" name="id">
        <div class="mb-3 h-25 text-center">
            <button class="btn btn-update w-75 h-50">Update</button>
        </div>
        <div class="message">
            {% if data.message is defined and data.message is not empty %}
                {% if data.success is true %}
                      <div  class="text-success w-100 text-center">{{ data.message}}</div>
                      {% else %}
                       <div  class="text-danger w-100 text-center">{{ data.message}}</div>
                {% endif %}
            {% endif %}
        </div>
    </form>
</div>
{% endblock %}
