{% extends 'base.html.twig' %}

{% block title %}Hello WerbungController!{% endblock %}

{% block body %}
<style>
.werbung-create{
    height:750px;
}
.werbung-create h1{
     font-size:100px;
}
.werbung-create .form{

}
.werbung-create input, .werbung-create label, .werbung-create textarea{
    font-size:50px;
}
input::placeholder{
    font-size:30px;
}
.werbung-create .btn-create{
    background-color: #820263;;
    color:white;
     font-size:50px;
}
.werbung-create .text-danger{
    font-size:30px;
}

</style>

<div class="werbung-create p-5">
    <h1 class="text-center">Create 'Werbung'</h1>
    <form class="form h-100 p-2" action="{{ path('werbung.save') }}" method="post" enctype="multipart/form-data">
        <div class="mb-3 mt-5 h-25">
            <label for="exampleFormControlInput1" class="form-label">Nr*:</label>
            <input type="number" name="nr" class="form-control h-50" id="exampleFormControlInput1" placeholder="Nr..." required>
            {% if data.err.nr is defined and data.err.nr is not empty %}
                <div class="text-danger mb-4"> {{ data.err.nr}}</div>
            {% endif %}
        </div>
        <div class="mb-3 mt-5 h-25">
            <label for="exampleFormControlInput1" class="form-label">Title:</label>
            <input type="text" name="title" class="form-control h-50" placeholder="Title..">
        </div>
        <div class="mb-3 mt-5 h-25">
            <label for="exampleFormControlInput1" class="form-label">Price:</label>
            <input type="number" step="0.1" name="price" class="form-control h-50" placeholder="Price..">
        </div>
        <div class="mb-5 mt-5 h-25">
            <label for="exampleFormControlTextarea1" class="form-label">Description</label>
            <textarea name="description" class="form-control h-100" id="exampleFormControlTextarea1" rows="3"></textarea>
        </div>
        <div class="mb-5 mt-5 h-25">
            <label for="exampleFormControlTextarea1" class="form-label">Image</label>
             <input type="file"  name="image" class="form-control h-50">
            {% if data.err.image is defined and data.err.image is not empty %}
                <div class="text-danger"> <p>{{ data.err.image}}</p></div>
            {% endif %}
        </div>
        <div class="mb-3 mt-5 h-25">
            <label for="exampleFormControlTextarea1" class="form-label">Video</label>
             <input type="file"  name="video" class="form-control h-50">
            {% if data.err.video is defined and data.err.video is not empty %}
                <div class="text-danger"> {{ data.err.video}}</div>
            {% endif %}
        </div>
        <div class="mb-3 mt-5 h-25">
            <label for="exampleFormControlInput1" class="form-label">Length of Video:</label>
            <input type="number" name="length"  step="0.10" class="form-control h-50" placeholder="Length in Sec...">
        </div>

        <div class="row">
        <h1 class="fw-large">Screens</h1>
        {% for screen in screens %}
           <div class="form-check col-md-12 ms-4">
                <input value="{{ screen.id }}" class="form-check-input" type="checkbox" name='screen{{screen.id}}' id="flexCheckDefault">
                <label class="form-check-label" for="flexCheckDefault">
                    {{ screen.title }}
                </label>
            </div>
        {% endfor %}
        {% if data.err.screen is defined and data.err.screen is not empty %}
            <div class="text-danger mb-4"> {{ data.err.screen}}</div>
        {% endif %}
        </div>
        <div class="mb-3 h-25 text-center">
            <button class="btn btn-create w-75 h-50">Create</button>
        </div>
        <div class="message">
            {% if data.message is defined and data.message is not empty %}
                {% if data.success is true %}
                      <div  class="text-success w-100 text-center">{{ data.message}}</div>
                      {% else %}
                       <div  class="text-danger w-100 text-center">{{ data.message}}</div>
                {% endif %}
            {% endif %}
        </div>
    </form>
</div>
{% endblock %}
