{% extends 'admin.html.twig' %}

{% block title %}Hello CategoryController!{% endblock %}

{% block body %}
<style>

.category-create .cover{
    background-color: #ffbf3f;
}
.category-create .btn{
    background-color: #820263;
    color:white
}

</style>

<div class="category-create d-flex justify-content-center align-items-center w-100">
    <div class="cover w-75 p-5 card">
        <h1> Category Create</h1>
        <form  action="{{ path('category.save') }}" method="post" enctype="multipart/form-data">
            <div class="mb-3">
                <label  class="form-label">Title*</label>
                <input name='title' type="text" class="form-control" placeholder="Title...." required>
            </div>
            <div class="mb-3">
                <label  class="form-label">Nr</label>
                <input name='nr' type="number" step="0" class="form-control" required>
            </div>
            <div class="mb-3">
                <label  class="form-label">Image</label>
                <input name="image" type="file" class="form-control">
            </div>
            <div class="form-check">
                <input class="form-check-input" type="checkbox" name="size">
                <label class="form-check-label">
                    The Articles of this Category have Sizes
                </label>
            </div>
            <div class="w-100 text-center">
                <button type="submit" class="btn w-50">Submit</button>
            <div>
        </form>
        <div class="message">
            {% if data.message is defined and data.message is not empty %}
                {% if data.success is true %}
                      <div  class="text-success w-100 text-center">{{ data.message}}</div>
                      {% else %}
                       <div  class="text-danger w-100 text-center">{{ data.message}}</div>
                {% endif %}
            {% endif %}
        </div>
    <div>
</div>
{% endblock %}
