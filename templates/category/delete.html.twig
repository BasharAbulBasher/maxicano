{% extends 'admin.html.twig' %}

{% block title %}Hello CategoryController!{% endblock %}

{% block body %}
<style>


</style>

<div class="category-delete container">
        {% if category is defined and category is not empty %}
        <div class="card">
            <h1 class="text-center">Would you like RELLEY delete this Category {{category.title}}</h1>
            <div class="row text-center">
                <div class="col-6">
                    <a class="btn btn-warning w-75" href="/admin/category/show">nein</a>
                </div>
                <div class="col-6">
                    <form  action="{{ path('category.remove') }}" method="post">
                        <input type="hidden" value="{{ category.id }}" name="id">
                         <button type="submit" class="btn btn-danger w-75">Ja</button>
                    </form>
                </div>
            </div>
        </div>
        {% endif %}

        <div class="message">
            {% if data.message is defined and data.message is not empty %}
                {% if data.success is true %}
                      <div  class="text-success w-100 text-center">{{ data.message}}</div>
                      {% else %}
                       <div  class="text-danger w-100 text-center">{{ data.message}}</div>
                {% endif %}
            {% endif %}
        </div>
    <div>
</div>
{% endblock %}

