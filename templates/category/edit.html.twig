{% extends 'admin.html.twig' %}

{% block title %}Hello CategoryController!{% endblock %}

{% block body %}
<style>
.category-edit .image img{
    width:200px;
    height:200px;
}
.category-edit .cover{
    background-color: #ffbf3f;
}
.category-edit .btn{
    background-color: #820263;
    color:white
}

</style>

<div class="category-edit d-flex justify-content-center align-items-center w-100">
    <div class="cover w-75 p-5 card">
        <h1> Category Create</h1>
        <div class="image text-center">
            <img src="/file/category/{{ category.image }}">
        </div>
        <form  action="{{ path('category.update') }}" method="post" enctype="multipart/form-data">
            <div class="mb-3">
                <label  class="form-label">Category Title</label>
                <input value='{{ category.title }}' name='title' type="text" class="form-control" placeholder="Title...." required>
            </div>
            <div class="mb-3">
                <label  class="form-label">Nr</label>
                <input value="{{ category.nr }}" name='nr' type="number" step="0" class="form-control" required>
            </div>
            <div class="mb-3">
                <label  class="form-label">Image</label>
                <input name="image" type="file" class="form-control">
            </div>
            <div class="form-check">
            {% if category.size == true %}
                <input class="form-check-input" type="checkbox" name="size" checked>
                <label class="form-check-label">
                    The Articles of this Category have Sizes
                </label>
                {% else %}
                <input class="form-check-input" type="checkbox" name="size">
                <label class="form-check-label">
                    The Articles of this Category have Sizes
                </label>
            {% endif %}

            </div>

            <div class="w-100 text-center">
                <button type="submit" class="btn w-50">Update</button>
            <div>
            <input name="id" type="hidden" value="{{ category.id }}">
        </form>
        <div class="message">
            {% if data.message is defined and data.message is not empty %}
                {% if data.success is true %}
                      <div  class="text-success w-100 text-center">{{ data.message}}</div>
                      {% else %}
                       <div  class="text-danger w-100 text-center">{{ data.message}}</div>
                {% endif %}
            {% endif %}
        </div>
    <div>
</div>
{% endblock %}

