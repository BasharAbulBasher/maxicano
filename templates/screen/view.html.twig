
{% extends 'screen.html.twig' %}

{% block title %}Hello ScreenController!{% endblock %}

{% block body %}
<style>

.article{
     overflow:hidden;
    animation: scale_up 1s ease both, scale_down 1s ease 6s both;
}
.article-title{
    height:20%;
    position:relative;
    left:-100%;
    animation: move_righte  1s ease 1s both;

}
.article-image{
    height:60%;
    width:100%
}

.article-price{
    color: #ffbf3f;
    background-color:#820263;
    position:relative;
    left:-100%;
    animation: move_righte  1s ease 1s both;
}
.article-price span{
    display:inline-block;
     animation: pulse  1s ease 1s infinite;
}
#video{
    position:absolute;
    top:-100%;
    left:0;
}
.moveDown{
    animation: moveDown 2s ease both;
}

@keyframes scale_up
{
    0%{
        transform: scale(0);
    }
    100%{
        transform: scale(1);
    }
}
@keyframes scale_down {
    0% {

    }

    100% {
        transform: scale(0);
    }
}
@keyframes move_righte {
    0% {
        left:-100%

    }

    100% {
        left:0%
    }
}
@keyframes pulse {
  50% {
    transform: scale(1.5);
  }
}

@keyframes moveDown {
    0% {
    }

    100% {
        top:0%
    }
}
@keyframes rotate {
    0% {
        transform: rotateY(90deg);
    }

    100% {
        transform: rotateY(0deg);

    }
}

</style>

<div id="screen" class="screen container">
    <div id="screen-body" class="body p-5">
    </div>
    <div id="werbung-cover">
    </div>
    <div class="message">
        {% if data.message is defined and data.message is not empty %}
            {% if data.success is not true %}
            <div class="text-danger w-100 text-center">{{ data.message}}</div>
            {% endif %}
        {% endif %}
    </div>
    <input value="{{ data.screenTitle }}" id="screenTitle" type="hidden">
</div>
<script>
    //Categories nesossory Veriables
    var categories;
    var categoriesLength;
    var category;
    var timer;
    var curentCategory=0;
    //'Werbungen' nesossory Veriables
    var werbungen;
    var werbungenLength;
    var werbung;
    var werbungTimer;
    var curentWerbung=0;
    var werbungTime;
    var finishWerbung=0;
    //pusher Veriable
    var pusher = new Pusher('913a250eb06be3f184c8', {
        cluster: 'eu'
    });
     //Fullscreen Using 'Event-click'
        const tv = document.getElementById("screen");
        tv.addEventListener("click", () => {
            if (!document.fullscreenElement) {
                // Noch nicht fullscreen → Vollbild aktivieren
                tv.requestFullscreen().catch(err => {
                    console.error("Fullscreen konnte nicht aktiviert werden:", err);
                });
            } else {
                // Bereits fullscreen → zurück
                document.exitFullscreen();
            }
        });
    //Play Directlley
    $.ajax({
        url: '{{ path("screen.visit") }}',
        data: {
                screenTitle: $("#screenTitle").val(),
        },
        type: 'POST',
        success: function(data) {
            init(data);
        }
    }); 
    //Play Using Pusher
    var channel=pusher.subscribe('screen');
    channel.bind('event', function(data) {
        var result=[];
        if($("#screenTitle").val() == 'tv1')
        {
            result['categories']=data['tv1'];
            result['werbungen']=data['tv1Werbungen'];
        }
        if($("#screenTitle").val() == 'tv2')
        {
            result['categories']=data['tv2'];
            result['werbungen']=data['tv2Werbungen'];
        }
        if($("#screenTitle").val() == 'tv3')
        {
            result['categories']=data['tv3'];
            result['werbungen']=data['tv3Werbungen'];
        }
        init(result);
      });
    function init(data)
    {
        console.log(data);
        //Set the Categories
        categories=data["categories"];
        //Set Timer of Category to change it
        timer=1500;
        //Get the Count of Categories
        categoriesLength=categories.length;
        //Set Index of curent Category
        curentCategory=0;
        //Set the 'Werbungen'
        werbungen=data['werbungen']
        //Set the Timer of 'Werbung' to change it
        werbungTimer=0;
        //Get the Count of 'Werbungen'
        werbungenLength=werbungen.length;
        //Set Index of curent Werbung
        curentWerbung=0;
        //Set Werbung Time
        werbungTime=100;
        //feuer the Animate
        animate();
    }
    function animate()
    {
        requestAnimationFrame(animate);
        //Update
        update();
    }
    function update()
    {
        //Update the Categories
        updateCategories()
        //Update the 'Werbungen'
        updateWerbungen()
    }
    function updateCategories()
    {
        //Inc the Timer
        timer++;
        if(timer>1000)
        {
            //Reset the Timer
            timer=0;
            //Reset the CurentCategory
            if(curentCategory == categoriesLength)
            {
                //Reset the curent Category
                curentCategory=0;
            }
            //Get the Category
            category=categories[curentCategory]
             //Inc the curent Category
            curentCategory++
            setArticles(category);
        }

    }
    function updateWerbungen()
    {
        //Inc WerbungTimer
        werbungTimer++;
        if(werbungTimer > werbungTime)
        {
            //Reset the Timer
            werbungTimer=0;
            //Reset the CurentWerbung
            if(curentWerbung == werbungenLength)
            {
                //Reset the curent Category
                curentWerbung=0;
            }
            //Get the Werbung
            werbung=werbungen[curentWerbung]
            //Set the Werbung Time
            setWerbungTime()
            //Inc the curent Werbung
            curentWerbung++
            displayWerbung()
        }
    }
    function setWerbungTime()
    {
        if(werbung['length']!= null)
        {
            werbungTime=werbung['length']*100;
        }
        else
        {
            werbungTime=500;
        }
    }
    function displayWerbung()
    {
        //Display Video
        if(werbung['video']!=null)
        {
            displayVideo();
        }
        //Display Image
        else{
            //displayImage(werbung)
        }
    }
    function displayVideo()
    {
        //Empty the Werbung Cover
        $("#werbung-cover").empty();
        //Set the Video in the Werbung Cover
        $("#werbung-cover").append(
            "<video id='video' muted width='100%; height:100%'>"+
                "<source src='/file/werbung/"+werbung['video']+"' type='video/mp4'>"+
            "</video>");
        $("#video").addClass('moveDown');
         $("#video")[0].play();

    }
    function setArticles(category)
    {
        //Empty Screen-Body
        $("#screen-body").empty();
        //Create Div Category
        $("#screen-body").append("<div id='category' class='row'></div>");
        //Set the Articles in Div Category
        $.each(category, function(index, article){
             $("#category").append("<div class='article col-6'>"+
                "<h1 class='article-title'>"+article['title']+"</h1>"+
                "<img  class='article-image' src='/file/article/"+article['image']+"'>"+
                "<h1 class='article-price p-2 text-center' class='price'><span>"+article['price']+"€</span></h1>"+
             "</div>");
        })
        //Get the Height of the Div Article
        var height=getArticleHeight(category);
        console.log(height);
        //Set the Height of the Article
        $(".article").css({
            'height':height+'px',
        })
    }
    function getArticleHeight(category)
    {
       return $(window).height()/Math.ceil(category.length/2);
    }
    function getRandom(to) {
        return 1 + Math.floor(Math.random() * to);
    }

animate();


</script>
{% endblock %}
