{% extends 'base.html.twig' %}

{% block title %}Create Article In Screen!{% endblock %}

{% block body %}
<style>
    .screen-createArticleInScreen  h1{
        font-size: 50px;
    }
   .screen-createArticleInScreen .accordion-button {
        font-size: 50px;
    }
    .screen-createArticleInScreen .article{
        font-size: 50px;
    }
   .screen-createArticleInScreen .article .price{
        font-size: 40px;
   }
    .screen-createArticleInScreen .article .image img{
        height:200px;
        width:200px;
    }
    .btn{
        font-size: 70px;
    }
</style>
 
<div class="screen-createArticleInScreen">
    <h1 class="text-center ">View Articles in {{screen.title}}</h1>
    <div class="message">
        {% if data.message is defined and data.message is not empty %}
            {% if data.success is true %}
                <div class="text-success w-100 text-center">{{ data.message}}</div>
            {% else %}
                <div class="text-danger w-100 text-center">{{ data.message}}</div>
            {% endif %}
        {% endif %}
    </div>
    <div class="accordion" id="accordionExample">
        <form  action="{{ path('screen.saveArticleInScreen') }}" method="post">
            {% for category in categories %}
            <div class="accordion-item">
                <h2 class="accordion-header" id="heading{{ category.id }}">
                    <button class="accordion-button" type="button" data-bs-toggle="collapse"
                        data-bs-target="#collapse{{ category.id }}" aria-expanded="true"
                        aria-controls="collapse{{ category.id }}">
                        {{ category.title }}
                    </button>
                </h2>
                <div id="collapse{{ category.id }}" class="accordion-collapse collapse"
                    aria-labelledby="heading{{ category.id }}" data-bs-parent="#accordionExample">
                    <div class="accordion-body">
                        {% for article in category.articles %}
                            {% set isView = false %}
                            {% for articleScreen in articlesScreen %}
                                {% if articleScreen.article.id == article.id %}
                                    {% set isView = true %}
                                {% endif %}
                            {% endfor %}
                        <div class="article row mb-2">
                            <div class="nr-title col-4">
                                <p>{{article.nr}}.{{article.title}}</p>
                                <div class="price">
                                    <p class="">Small:{{article.smallPrice}}€ , Big:{{article.price}}€</p>
                                </div>
                            </div>
                            <div class="image col-4 text-center">
                                <img  src="/file/article/{{ article.image }}">
                            </div>

                            <div class=" col-4 text-end">
                            {% if isView == true %}
                            <input class="form-check-input" type="checkbox" value="{{ article.id }}" name="{{ article.id }}" checked>
                            {% else %}
                            <input class="form-check-input" type="checkbox" value="{{ article.id }}" name="{{ article.id }}">
                            {% endif %}
                                <label class="mt-3" for="flexCheckDefault">
                                    View in {{ screen.title }}
                                </label>
                            </div>
                        </div>
                        {% endfor %}
                    </div>
                </div>
            </div>
            {% endfor %}
            <input type="hidden" name="screenId" value="{{ screen.id }}">
            <input type="hidden" name="screenTitle" value="{{ screen.title }}">
        <button type="submit" class="btn btn-warning w-100 mt-2">Save</button>
        </form>
    </div>

</div>

{% endblock %}

