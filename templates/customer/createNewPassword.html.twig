{% extends 'customer.html.twig' %}

{% block title %}Customer Login!{% endblock %}

{% block body %}
<style>
.customer-createNewPassword {
height:1000px;
font-size:50px;
font-family: fantasy;
}
.customer-createNewPassword .btn-register
{
background-color:#820263;
color:white;
font-size:50px;
}
input
{
font-size:50px;
border:none;
border-bottom:1px solid #820263;
}
input::placeholder{
font-size:50px;
}
input:focus{
outline: none;
}
</style>

<div class="customer-createNewPassword">
    <div class="d-flex justify-content-center align-items-center">
        <form class="form p-3 h-75 col-12" action="{{ path('customer.createNewPasswordTest') }}" method="post">
            <div class="mb-1 h-25 row">
                <label class="form-label col-12">Email*</label>
                <input name='email' type="email" class="col-12 h-50" placeholder="Email@hotmail.com...." required>
                    {% if data.errors.email is defined %}
                        <small class="text-danger">{{data.errors.email}}</small>
                    {% endif %}
            </div>
            <div class="mb-1 h-25 row">
                <label class="form-label col-12">New Password*</label>
                <input name='newPassword' type="text" class="col-12 h-50" placeholder="pasword...." required>
                    {% if data.errors.newPassword is defined %}
                        <small class="text-danger">{{data.errors.newPassword}}</small>
                    {% endif %}
            </div>
            <div class="mb-1 h-25 row">
                <label class="form-label col-12">Confirm new Password*</label>
                <input name='confirmNewPassword' type="text" class="col-12 h-50" placeholder="pasword...." required>
                    {% if data.errors.confirmNewPassword is defined %}
                        <small class="text-danger">{{data.errors.confirmNewPassword}}</small>
                    {% endif %}
            </div>
            <div class="w-100 h-25 text-center">
                <button type="submit" class="btn w-50 h-50 btn-register">Reset Password</button>
            <div>
        </form>

        <div class="message">
            {% if data.message is defined and data.message is not empty %}
            {% if data.success is true %}
            <div class="text-success w-100 text-center">{{ data.message}}</div>
            {% else %}
            <div class="text-danger w-100 text-center">{{ data.message}}</div>
            {% endif %}
            {% endif %}
        </div>
    </div>
</div>

{% endblock %}



